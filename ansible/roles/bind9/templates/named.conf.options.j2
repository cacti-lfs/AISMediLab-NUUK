options {
    directory "/var/cache/bind";

    recursion yes;
    allow-recursion {
{% for network in bind9_allowed_networks %}
        {{ network }};
{% endfor %}
        localhost;
        localnets;
    };

    listen-on {
        any;
    };

    listen-on-v6 {
        none;
    };

    allow-query {
{% for network in bind9_allowed_networks %}
        {{ network }};
{% endfor %}
        localhost;
        localnets;
    };

    forwarders {
{% for forwarder in bind9_forwarders %}
        {{ forwarder }};
{% endfor %}
    };

    dnssec-validation auto;

    auth-nxdomain no;
};
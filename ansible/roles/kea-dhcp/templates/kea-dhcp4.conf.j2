{
  "Dhcp4": {
    "interfaces-config": {
      "interfaces": ["{{ kea_interface | default('*') }}"]
    },
    "lease-database": {
      "type": "memfile",
      "lfc-interval": 3600
    },
    "valid-lifetime": 3600,
    "renew-timer": 900,
    "rebind-timer": 1800,
    "option-data": [
      {
        "name": "domain-name-servers",
        "data": "{{ dns_servers | join(', ') }}"
      },
      {
        "name": "domain-name",
        "data": "{{ domain_name }}"
      }
    ],
    "subnet4": [
{% for subnet in dhcp_subnets %}
      {
        "id": {{ subnet.id }},
        "subnet": "{{ subnet.subnet }}",
{% if subnet.relay is defined %}
        "relay": {
          "ip-addresses": ["{{ subnet.relay }}"]
        },
{% endif %}
        "pools": [
          {
            "pool": "{{ subnet.pool_start }} - {{ subnet.pool_end }}"
          }
        ],
        "option-data": [
          {
            "name": "routers",
            "data": "{{ subnet.router }}"
          }
        ]
      }{% if not loop.last %},{% endif %}
{% endfor %}
    ],
    "hooks-libraries": [
      {
        "library": "/usr/lib/x86_64-linux-gnu/kea/hooks/libdhcp_ha.so",
        "parameters": {
          "high-availability": [
            {
              "this-server-name": "{{ inventory_hostname }}",
              "mode": "hot-standby",
              "heartbeat-delay": 10,
              "max-response-delay": 60,
              "control-socket": {
                "socket-type": "unix",
                "socket-name": "/run/kea/kea4-ctrl-socket"
              },
              "peers": [
                {
                  "name": "{{ kea_peer_primary }}",
                  "url": "http://{{ kea_primary_ip }}:{{ kea_ctrl_agent_port }}/",
                  "role": "primary"
                },
                {
                  "name": "{{ kea_peer_standby }}",
                  "url": "http://{{ kea_secondary_ip }}:{{ kea_ctrl_agent_port }}/",
                  "role": "standby"
                }
              ]
            }
          ]
        }
      }
    ],
    "loggers": [
      {
        "name": "kea-dhcp4",
        "output_options": [
          {
            "output": "syslog"
          }
        ],
        "severity": "INFO"
      }
    ]
  }
}
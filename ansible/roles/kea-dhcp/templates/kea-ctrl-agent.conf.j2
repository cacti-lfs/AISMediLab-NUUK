{
  "Control-agent": {

    "http-host": "{{ ansible_host }}",

    "http-port": {{ kea_ctrl_agent_port }},

    "control-sockets": {
      "dhcp4": {
        "socket-type": "unix",
        "socket-name": "/run/kea/kea4-ctrl-socket"
      }
    },

    "authentication": {
      "type": "basic",
      "realm": "kea-control-agent",

      "clients": [
        {
          "user": "kea-api",
          "password-file": "/etc/kea/kea-api-password"
        }
      ]
    },

    "loggers": [
      {
        "name": "kea-ctrl-agent",
        "output_options": [
          {
            "output": "syslog"
          }
        ],
        "severity": "INFO",
        "debuglevel": 0
      }
    ]
  }
}